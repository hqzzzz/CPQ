# ==================================
# CPQ Backend Environment Configuration Example
#  CPQ 系统后端环境变量配置示例
# ==================================
# 
# 使用方法：
# 1. 将此文件复制为 .env
#    cp .env.example .env
# 2. 根据实际需求修改以下配置项
# 3. 确保后端项目已安装依赖：npm install
#

# ---------------------------------
# Server Configuration
# 服务器配置
# ---------------------------------
# 服务端口
PORT=3002

# 服务监听地址
HOST=0.0.0.0

# ---------------------------------
# Database Configuration (MySQL)
# 数据库配置 (MySQL)
# ---------------------------------
# MySQL 服务器地址
DB_HOST=localhost

# MySQL 端口
DB_PORT=3306

# MySQL 用户名
DB_USER=root

# MySQL 密码
DB_PASSWORD=your_password_here

# 数据库名称
DB_NAME=cpq_database

# ---------------------------------
# Security Configuration
# 安全配置
# ---------------------------------
# Bootstrap Key (多用户环境下建议设置固定值)
# 用于系统初始化或紧急管理员访问，仅限本机使用
# 不设置则随机生成
BOOTSTRAP_KEY=

# JWT 密钥 (用于 Token 签名)
JWT_SECRET=your_jwt_secret_key_here

# JWT 过期时间
JWT_EXPIRES_IN=7d

# ---------------------------------
# CORS Configuration
# 跨域配置
# ---------------------------------
# 允许跨域的前端地址
CORS_ORIGIN=http://localhost:5173

# 允许的 HTTP 方法
CORS_METHODS=GET,POST,PUT,DELETE

# ---------------------------------
# File Storage Configuration
# 文件存储配置
# ---------------------------------
# BUCK (Bucket) 根目录，用于存储上传文件
# 相对于后端项目根目录路径或绝对路径
BUCK_ROOT=./BUCK

# ---------------------------------
# Logging Configuration
# 日志配置
# ---------------------------------
# 日志级别
# 可用级别：debug, info, warn, error
LOG_LEVEL=info

# ---------------------------------
# Optional: External Services
# 可选：外部服务配置
# ---------------------------------
# AI API 配置 (如使用)
# AI_API_KEY=your_ai_api_key_here
# AI_API_URL=https://api.example.com